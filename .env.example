# ═══════════════════════════════════════════════════════════════════════════════
#  Kizuna — docker-compose environment
#
#  Copy this file to .env and fill in the values marked  ← REQUIRED
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Domain (required for HTTPS via Caddy) ─────────────────────────────────────

# ← REQUIRED — The domain name pointing to this server. Caddy will automatically
# obtain a Let's Encrypt TLS certificate for this domain and reverse-proxy HTTPS
# traffic to the Kizuna server.
# The domain must have an A record pointing to this server's public IP.
DOMAIN=

# ─── Security ──────────────────────────────────────────────────────────────────

# ← REQUIRED — Secret used to sign and verify authentication tokens.
# Generate with: openssl rand -hex 64
JWT_SECRET=

# ─── Server identity ───────────────────────────────────────────────────────────

# Port the Kizuna HTTP server listens on inside the container. Caddy reverse-proxies
# to this internal port. The port is NOT exposed to the host (Caddy handles external access).
SERVER_PORT=5000

# Display name shown to clients.
SERVER_NAME=Kizuna Server

# Short description shown to clients.
SERVER_DESCRIPTION=A self-hosted Kizuna community

# Full HTTPS URL where this server is accessible. Used for invite codes so
# recipients get the correct URL. Should match your domain.
# Example: SERVER_URL=https://chat.example.com
SERVER_URL=

# Optional join password. Anyone registering an account must supply this.
# Leave blank to allow anyone to join freely.
SERVER_PASSWORD=

# ─── WebRTC / Voice ───────────────────────────────────────────────────────────

# Your server's public IPv4 address (or DDNS hostname) used as the WebRTC ICE
# candidate for voice. This is the address clients connect to for UDP media.
#
#   Static IP:  PUBLIC_ADDRESS=203.0.113.42
#   DDNS:       PUBLIC_ADDRESS=yourserver.duckdns.org
#   Domain:     PUBLIC_ADDRESS=chat.example.com  (resolved to IPv4 at startup)
#
# Leave blank to auto-detect via STUN — works for most home hosting setups.
PUBLIC_ADDRESS=

# UDP port range reserved for WebRTC voice. Each active voice participant uses
# roughly 2 ports. These ports are exposed directly to the host (Caddy cannot
# proxy UDP). Ensure they are open in your firewall.
RTC_MIN_PORT=40000
RTC_MAX_PORT=40099

# ─── GIFs & Stickers ──────────────────────────────────────────────────────────
# Directory for GIF and sticker file storage inside the container.
# GIFS_DIR=/data/gifs
# Maximum file size for a single GIF/sticker in bytes. Default: 5MB.
# MAX_GIF_SIZE=5242880

# ─── Features ──────────────────────────────────────────────────────────────────

# UPnP port mapping. Disable when using Caddy (docker-compose already maps ports).
UPNP_ENABLED=false
