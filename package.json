{
  "name": "kizuna",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Kizuna — self-hosted Discord alternative with chat, voice, and screen sharing",
  "scripts": {
    "dev": "pnpm --filter @kizuna/server dev",
    "dev:server": "pnpm --filter @kizuna/server dev",
    "dev:desktop": "pnpm --filter @kizuna/desktop dev",
    "tauri:dev": "WEBKIT_DISABLE_COMPOSITING_MODE=1 WEBKIT_DISABLE_DMABUF_RENDERER=1 pnpm --filter @kizuna/desktop tauri dev",
    "tauri:build": "pnpm --filter @kizuna/desktop tauri build",
    "build": "pnpm --filter @kizuna/server build && pnpm --filter @kizuna/desktop build",
    "build:server": "pnpm --filter @kizuna/server build",
    "build:desktop": "pnpm --filter @kizuna/desktop build",
    "start": "pnpm --filter @kizuna/server start",
    "typecheck": "pnpm run --recursive typecheck",
    "typecheck:server": "pnpm --filter @kizuna/server typecheck",
    "typecheck:desktop": "pnpm --filter @kizuna/desktop typecheck",
    "typecheck:shared": "pnpm --filter @kizuna/shared typecheck",
    "lint": "pnpm run --recursive lint",
    "lint:server": "pnpm --filter @kizuna/server lint",
    "lint:desktop": "pnpm --filter @kizuna/desktop lint",
    "lint:shared": "pnpm --filter @kizuna/shared lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test": "pnpm --filter @kizuna/shared test",
    "test:watch": "pnpm --filter @kizuna/shared test:watch",
    "clean": "pnpm --filter @kizuna/server clean && pnpm --filter @kizuna/desktop clean"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.9"
  }
}
